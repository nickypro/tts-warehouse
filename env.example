# TTS Configuration
UNREALSPEECH_API_KEY=your_key_here
TTS_ENGINE=unrealspeech  # unrealspeech | openai | kokoro_api
TTS_VOICE_ID=Scarlett

# Server
WEB_HOST=0.0.0.0
WEB_PORT=8000
BASE_URL=http://localhost:8000

# Database
DATABASE_PATH=./data/db.sqlite

# Processing
LAZY_THRESHOLD=10  # Items >= this use lazy processing

# OpenRouter (for AI summaries in feed descriptions)
OPENROUTER_API_KEY=your_key_here
SUMMARY_MODEL=google/gemini-3-flash-preview

# Auth
ADMIN_PASSWORD=
